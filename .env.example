# === WandB ===
WANDB_API_KEY=your_wandb_api_key_here

# === HuggingFace (optional, for gated models or pushing to hub) ===
HF_TOKEN=your_hf_token_here

# === BrowserGym ===
# URL where the BrowserGym environment is accessible
# This is set automatically by docker-compose, but you can override it
BROWSERGYM_URL=http://browsergym-env:7860
